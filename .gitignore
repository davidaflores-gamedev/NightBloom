bin/
lib/
*.exe
*.dll
*.pdb
*.ilk
*.lib
*.obj
*.o
*.a
*.exp

# ==== Shader artifacts (keep source .vert/.frag/.comp, ignore compiled) ====
*.spv

# ==== Logs and runtime files ====
*.log
engine.log
imgui.ini

# ==== OS files ====
.DS_Store
Thumbs.db
desktop.ini

# ==== IDE ====
.idea/
.vscode/
*.swp
*~

